{
  "tests": [
    {
      "name": "Reject without secret header",
      "method": "POST",
      "path": "/",
      "body": {"message": {"text": "/start", "chat": {"id": 123}}},
      "expectedStatus": 403,
      "expectedBody": {"error": "Forbidden"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Reject wrong secret",
      "method": "POST",
      "path": "/",
      "headers": {"X-Telegram-Bot-Api-Secret-Token": "wrong-secret-value"},
      "body": {"message": {"text": "/start", "chat": {"id": 123}}},
      "expectedStatus": 403,
      "expectedBody": {"error": "Forbidden"},
      "bodyMatcher": "partial"
    }
  ]
}
