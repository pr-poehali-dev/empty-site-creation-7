{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "No init_data forbidden on GET",
      "method": "GET",
      "path": "/",
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "No init_data forbidden on POST",
      "method": "POST",
      "path": "/",
      "body": {"action": "create"},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
