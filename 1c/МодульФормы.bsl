
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    ЗагрузитьНастройки();
КонецПроцедуры

&НаСервере
Процедура ПриЗакрытииНаСервере()
    СохранитьНастройки();
КонецПроцедуры

#КонецОбласти

#Область НастройкиХранилище

&НаСервере
Процедура СохранитьНастройки()
    Настройки = Новый Структура;
    Настройки.Вставить("АдресСервера", Объект.АдресСервера);
    Настройки.Вставить("КлючAPI", Объект.КлючAPI);

    ТаблицаПолей = Новый ТаблицаЗначений;
    ТаблицаПолей.Колонки.Добавить("ПолеСайта");
    ТаблицаПолей.Колонки.Добавить("ОписаниеПоля");
    ТаблицаПолей.Колонки.Добавить("Обязательное");
    ТаблицаПолей.Колонки.Добавить("РеквизитНоменклатуры");
    Для Каждого Строка Из Объект.СопоставлениеПолей Цикл
        НоваяСтрока = ТаблицаПолей.Добавить();
        НоваяСтрока.ПолеСайта = Строка.ПолеСайта;
        НоваяСтрока.ОписаниеПоля = Строка.ОписаниеПоля;
        НоваяСтрока.Обязательное = Строка.Обязательное;
        НоваяСтрока.РеквизитНоменклатуры = Строка.РеквизитНоменклатуры;
    КонецЦикла;
    Настройки.Вставить("СопоставлениеПолей", ТаблицаПолей);

    ТаблицаЦен = Новый ТаблицаЗначений;
    ТаблицаЦен.Колонки.Добавить("ВидЦеныСайта");
    ТаблицаЦен.Колонки.Добавить("ОписаниеЦены");
    ТаблицаЦен.Колонки.Добавить("ТипЦен1С");
    Для Каждого Строка Из Объект.СопоставлениеЦен Цикл
        НоваяСтрока = ТаблицаЦен.Добавить();
        НоваяСтрока.ВидЦеныСайта = Строка.ВидЦеныСайта;
        НоваяСтрока.ОписаниеЦены = Строка.ОписаниеЦены;
        НоваяСтрока.ТипЦен1С = Строка.ТипЦен1С;
    КонецЦикла;
    Настройки.Вставить("СопоставлениеЦен", ТаблицаЦен);

    ХранилищеОбщихНастроек.Сохранить("ОбменССайтом", "Настройки", Настройки);
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьНастройки()
    Настройки = ХранилищеОбщихНастроек.Загрузить("ОбменССайтом", "Настройки");
    Если Настройки = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Если Настройки.Свойство("АдресСервера") Тогда
        Объект.АдресСервера = Настройки.АдресСервера;
    КонецЕсли;
    Если Настройки.Свойство("КлючAPI") Тогда
        Объект.КлючAPI = Настройки.КлючAPI;
    КонецЕсли;

    Если Настройки.Свойство("СопоставлениеПолей") Тогда
        Объект.СопоставлениеПолей.Очистить();
        Для Каждого Строка Из Настройки.СопоставлениеПолей Цикл
            НоваяСтрока = Объект.СопоставлениеПолей.Добавить();
            НоваяСтрока.ПолеСайта = Строка.ПолеСайта;
            НоваяСтрока.ОписаниеПоля = Строка.ОписаниеПоля;
            НоваяСтрока.Обязательное = Строка.Обязательное;
            НоваяСтрока.РеквизитНоменклатуры = Строка.РеквизитНоменклатуры;
        КонецЦикла;
    КонецЕсли;

    Если Настройки.Свойство("СопоставлениеЦен") Тогда
        Объект.СопоставлениеЦен.Очистить();
        Для Каждого Строка Из Настройки.СопоставлениеЦен Цикл
            НоваяСтрока = Объект.СопоставлениеЦен.Добавить();
            НоваяСтрока.ВидЦеныСайта = Строка.ВидЦеныСайта;
            НоваяСтрока.ОписаниеЦены = Строка.ОписаниеЦены;
            НоваяСтрока.ТипЦен1С = Строка.ТипЦен1С;
        КонецЦикла;
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область КомандыВкладкиСопоставление

&НаКлиенте
Процедура ЗагрузитьСтруктуруСайта(Команда)
    Если ПустаяСтрока(Объект.АдресСервера) ИЛИ ПустаяСтрока(Объект.КлючAPI) Тогда
        ПоказатьПредупреждение(, "Укажите адрес сервера и API-ключ");
        Возврат;
    КонецЕсли;

    ЗагрузитьСтруктуруСайтаНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСтруктуруСайтаНаСервере()
    Ответ = ВыполнитьЗапросHTTP("GET", "?action=schema", , Объект.КлючAPI);
    Если Ответ = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Данные = РазобратьJSON(Ответ);
    Если Данные = Неопределено Тогда
        Возврат;
    КонецЕсли;

    СуществующиеСопоставления = Новый Соответствие;
    Для Каждого Строка Из Объект.СопоставлениеПолей Цикл
        Если НЕ ПустаяСтрока(Строка.РеквизитНоменклатуры) Тогда
            СуществующиеСопоставления.Вставить(Строка.ПолеСайта, Строка.РеквизитНоменклатуры);
        КонецЕсли;
    КонецЦикла;

    СуществующиеЦены = Новый Соответствие;
    Для Каждого Строка Из Объект.СопоставлениеЦен Цикл
        Если ЗначениеЗаполнено(Строка.ТипЦен1С) Тогда
            СуществующиеЦены.Вставить(Строка.ВидЦеныСайта, Строка.ТипЦен1С);
        КонецЕсли;
    КонецЦикла;

    Объект.СопоставлениеПолей.Очистить();
    Если Данные.Свойство("product_fields") Тогда
        Для Каждого Поле Из Данные.product_fields Цикл
            НоваяСтрока = Объект.СопоставлениеПолей.Добавить();
            НоваяСтрока.ПолеСайта = Поле.key;
            НоваяСтрока.ОписаниеПоля = Поле.label;
            НоваяСтрока.Обязательное = Поле.required;
            Сопоставление = СуществующиеСопоставления.Получить(Поле.key);
            Если Сопоставление <> Неопределено Тогда
                НоваяСтрока.РеквизитНоменклатуры = Сопоставление;
            КонецЕсли;
        КонецЦикла;
    КонецЕсли;

    Объект.СопоставлениеЦен.Очистить();
    Если Данные.Свойство("price_types") Тогда
        Для Каждого Цена Из Данные.price_types Цикл
            НоваяСтрока = Объект.СопоставлениеЦен.Добавить();
            НоваяСтрока.ВидЦеныСайта = Цена.key;
            НоваяСтрока.ОписаниеЦены = Цена.label;
            Сопоставление = СуществующиеЦены.Получить(Цена.key);
            Если Сопоставление <> Неопределено Тогда
                НоваяСтрока.ТипЦен1С = Сопоставление;
            КонецЕсли;
        КонецЦикла;
    КонецЕсли;

    СохранитьНастройки();
КонецПроцедуры

#КонецОбласти

#Область КомандыВкладкиОбмен

&НаКлиенте
Процедура ЗаполнитьСписокТоваров(Команда)
    ЗаполнитьСписокТоваровНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокТоваровНаСервере()
    Объект.ТоварыДляВыгрузки.Очистить();

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Номенклатура.Ссылка КАК Номенклатура
        |ИЗ
        |   Справочник.Номенклатура КАК Номенклатура
        |ГДЕ
        |   НЕ Номенклатура.ЭтоГруппа
        |   И НЕ Номенклатура.ПометкаУдаления";

    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();
    Пока Выборка.Следующий() Цикл
        НоваяСтрока = Объект.ТоварыДляВыгрузки.Добавить();
        НоваяСтрока.Номенклатура = Выборка.Номенклатура;
        НоваяСтрока.Выгружать = Истина;
    КонецЦикла;

    ДобавитьЛог("Заполнено товаров: " + Объект.ТоварыДляВыгрузки.Количество());
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьНаСайт(Команда)
    Если ПустаяСтрока(Объект.АдресСервера) ИЛИ ПустаяСтрока(Объект.КлючAPI) Тогда
        ПоказатьПредупреждение(, "Укажите адрес сервера и API-ключ");
        Возврат;
    КонецЕсли;

    КоличествоДляВыгрузки = 0;
    Для Каждого Строка Из Объект.ТоварыДляВыгрузки Цикл
        Если Строка.Выгружать Тогда
            КоличествоДляВыгрузки = КоличествоДляВыгрузки + 1;
        КонецЕсли;
    КонецЦикла;

    Если КоличествоДляВыгрузки = 0 Тогда
        ПоказатьПредупреждение(, "Нет товаров для выгрузки");
        Возврат;
    КонецЕсли;

    ВыгрузитьНаСайтНаСервере();
КонецПроцедуры

&НаСервере
Процедура ВыгрузитьНаСайтНаСервере()
    МассивТоваров = Новый Массив;

    Для Каждого Строка Из Объект.ТоварыДляВыгрузки Цикл
        Если НЕ Строка.Выгружать Тогда
            Продолжить;
        КонецЕсли;

        Номенклатура = Строка.Номенклатура;
        ДанныеТовара = Новый Структура;
        ДанныеТовара.Вставить("external_id", Строка(Номенклатура.УникальныйИдентификатор()));

        Для Каждого СтрокаПоля Из Объект.СопоставлениеПолей Цикл
            Если ПустаяСтрока(СтрокаПоля.РеквизитНоменклатуры) Тогда
                Продолжить;
            КонецЕсли;
            Попытка
                Значение = Строка(Eval("Номенклатура." + СтрокаПоля.РеквизитНоменклатуры));
                ДанныеТовара.Вставить(СтрокаПоля.ПолеСайта, Значение);
            Исключение
            КонецПопытки;
        КонецЦикла;

        Если Номенклатура.Родитель <> Справочники.Номенклатура.ПустаяСсылка() Тогда
            ДанныеТовара.Вставить("category_name", Строка(Номенклатура.Родитель));
            ДанныеТовара.Вставить("category_external_id", Строка(Номенклатура.Родитель.УникальныйИдентификатор()));
        КонецЕсли;

        Для Каждого СтрокаЦены Из Объект.СопоставлениеЦен Цикл
            Если НЕ ЗначениеЗаполнено(СтрокаЦены.ТипЦен1С) Тогда
                Продолжить;
            КонецЕсли;
            Попытка
                ЦенаЗначение = 0;
                Запрос = Новый Запрос;
                Запрос.Текст =
                    "ВЫБРАТЬ
                    |   Цены.Цена
                    |ИЗ
                    |   РегистрСведений.ЦеныНоменклатуры.СрезПоследних КАК Цены
                    |ГДЕ
                    |   Цены.Номенклатура = &Номенклатура
                    |   И Цены.ВидЦены = &ВидЦены";
                Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
                Запрос.УстановитьПараметр("ВидЦены", СтрокаЦены.ТипЦен1С);
                Результат = Запрос.Выполнить();
                Если НЕ Результат.Пустой() Тогда
                    Выборка = Результат.Выбрать();
                    Выборка.Следующий();
                    ЦенаЗначение = Выборка.Цена;
                КонецЕсли;
                ДанныеТовара.Вставить(СтрокаЦены.ВидЦеныСайта, ЦенаЗначение);
            Исключение
            КонецПопытки;
        КонецЦикла;

        МассивТоваров.Добавить(ДанныеТовара);
    КонецЦикла;

    РазмерПакета = 500;
    Всего = МассивТоваров.Количество();
    Создано = 0;
    Обновлено = 0;
    Ошибок = 0;

    Для Индекс = 0 По Всего - 1 Цикл
        НомерПакета = Цел(Индекс / РазмерПакета);
        Если Индекс % РазмерПакета = 0 Тогда
            Пакет = Новый Массив;
        КонецЕсли;

        Пакет.Добавить(МассивТоваров[Индекс]);

        Если Пакет.Количество() = РазмерПакета ИЛИ Индекс = Всего - 1 Тогда
            Тело = Новый Структура("products", Пакет);
            Ответ = ВыполнитьЗапросHTTP("POST", "?action=products", Тело, Объект.КлючAPI);
            Если Ответ <> Неопределено Тогда
                Данные = РазобратьJSON(Ответ);
                Если Данные <> Неопределено Тогда
                    Если Данные.Свойство("created") Тогда Создано = Создано + Данные.created; КонецЕсли;
                    Если Данные.Свойство("updated") Тогда Обновлено = Обновлено + Данные.updated; КонецЕсли;
                    Если Данные.Свойство("errors") И Данные.errors.Количество() > 0 Тогда
                        Ошибок = Ошибок + Данные.errors.Количество();
                        Для Каждого Ошибка Из Данные.errors Цикл
                            ТекстОшибки = "";
                            Если Ошибка.Свойство("error") Тогда ТекстОшибки = Ошибка.error; КонецЕсли;
                            ДобавитьЛог("Ошибка: " + ТекстОшибки);
                        КонецЦикла;
                    КонецЕсли;
                КонецЕсли;
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;

    ДобавитьЛог("Выгрузка завершена. Создано: " + Создано + ", Обновлено: " + Обновлено + ", Ошибок: " + Ошибок);
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьССайта(Команда)
    Если ПустаяСтрока(Объект.АдресСервера) ИЛИ ПустаяСтрока(Объект.КлючAPI) Тогда
        ПоказатьПредупреждение(, "Укажите адрес сервера и API-ключ");
        Возврат;
    КонецЕсли;

    ЗагрузитьССайтаНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьССайтаНаСервере()
    Ответ = ВыполнитьЗапросHTTP("GET", "?action=products", , Объект.КлючAPI);
    Если Ответ = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Данные = РазобратьJSON(Ответ);
    Если Данные = Неопределено ИЛИ НЕ Данные.Свойство("products") Тогда
        ДобавитьЛог("Ошибка: некорректный ответ сервера");
        Возврат;
    КонецЕсли;

    Загружено = 0;
    Для Каждого Товар Из Данные.products Цикл
        ИдСайта = 0;
        Если Товар.Свойство("id") Тогда ИдСайта = Товар.id; КонецЕсли;

        ВнешнийИд = "";
        Если Товар.Свойство("external_id") И Товар.external_id <> Null Тогда
            ВнешнийИд = Товар.external_id;
        КонецЕсли;

        Наименование = "";
        Если Товар.Свойство("name") Тогда Наименование = Товар.name; КонецЕсли;

        ДобавитьЛог("Товар с сайта: " + Наименование + " (id=" + ИдСайта + ", external_id=" + ВнешнийИд + ")");
        Загружено = Загружено + 1;
    КонецЦикла;

    ДобавитьЛог("Загружено с сайта: " + Загружено + " товаров. Создание номенклатуры — вручную.");
КонецПроцедуры

&НаКлиенте
Процедура СвязатьССайтом(Команда)
    Если ПустаяСтрока(Объект.АдресСервера) ИЛИ ПустаяСтрока(Объект.КлючAPI) Тогда
        ПоказатьПредупреждение(, "Укажите адрес сервера и API-ключ");
        Возврат;
    КонецЕсли;

    СвязатьССайтомНаСервере();
КонецПроцедуры

&НаСервере
Процедура СвязатьССайтомНаСервере()
    МассивСвязок = Новый Массив;

    Для Каждого Строка Из Объект.ТоварыДляВыгрузки Цикл
        Если Строка.ИдСайта = 0 Тогда
            Продолжить;
        КонецЕсли;

        Связка = Новый Структура;
        Связка.Вставить("id", Строка.ИдСайта);
        Связка.Вставить("external_id", Строка(Строка.Номенклатура.УникальныйИдентификатор()));
        МассивСвязок.Добавить(Связка);
    КонецЦикла;

    Если МассивСвязок.Количество() = 0 Тогда
        ДобавитьЛог("Нет товаров с заполненным ИдСайта для связывания");
        Возврат;
    КонецЕсли;

    Тело = Новый Структура("links", МассивСвязок);
    Ответ = ВыполнитьЗапросHTTP("POST", "?action=link_products", Тело, Объект.КлючAPI);
    Если Ответ <> Неопределено Тогда
        Данные = РазобратьJSON(Ответ);
        Если Данные <> Неопределено И Данные.Свойство("linked") Тогда
            ДобавитьЛог("Связано товаров: " + Данные.linked);
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедуры

&НаСервере
Функция ВыполнитьЗапросHTTP(Метод, Путь, Тело = Неопределено, КлючАвторизации = "")
    Попытка
        АдресURL = Объект.АдресСервера;
        Если Лев(АдресURL, 8) = "https://" Тогда
            Сервер = Сред(АдресURL, 9);
        ИначеЕсли Лев(АдресURL, 7) = "http://" Тогда
            Сервер = Сред(АдресURL, 8);
        Иначе
            Сервер = АдресURL;
        КонецЕсли;

        ПозицияСлеш = Найти(Сервер, "/");
        Если ПозицияСлеш > 0 Тогда
            БазовыйПуть = Сред(Сервер, ПозицияСлеш);
            Сервер = Лев(Сервер, ПозицияСлеш - 1);
        Иначе
            БазовыйПуть = "";
        КонецЕсли;

        Соединение = Новый HTTPСоединение(Сервер, 443, , , , 30, Новый ЗащищенноеСоединениеOpenSSL);
        Заголовки = Новый Соответствие;
        Заголовки.Вставить("Content-Type", "application/json");
        Если НЕ ПустаяСтрока(КлючАвторизации) Тогда
            Заголовки.Вставить("X-Api-Key", КлючАвторизации);
        КонецЕсли;

        Запрос = Новый HTTPЗапрос(БазовыйПуть + Путь, Заголовки);

        Если Тело <> Неопределено Тогда
            ЗаписьJSON = Новый ЗаписьJSON;
            ЗаписьJSON.УстановитьСтроку();
            ЗаписатьJSON(ЗаписьJSON, Тело);
            ТелоСтрока = ЗаписьJSON.Закрыть();
            Запрос.УстановитьТелоИзСтроки(ТелоСтрока, КодировкаТекста.UTF8);
        КонецЕсли;

        Если ВРег(Метод) = "GET" Тогда
            Ответ = Соединение.Получить(Запрос);
        ИначеЕсли ВРег(Метод) = "POST" Тогда
            Ответ = Соединение.ОтправитьДляОбработки(Запрос);
        Иначе
            ДобавитьЛог("Неизвестный метод: " + Метод);
            Возврат Неопределено;
        КонецЕсли;

        Если Ответ.КодСостояния >= 400 Тогда
            ДобавитьЛог("Ошибка HTTP " + Ответ.КодСостояния + ": " + Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8));
            Возврат Неопределено;
        КонецЕсли;

        Возврат Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);

    Исключение
        ДобавитьЛог("Ошибка HTTP-запроса: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;
КонецФункции

&НаСервере
Функция РазобратьJSON(Строка)
    Попытка
        ЧтениеJSON = Новый ЧтениеJSON;
        ЧтениеJSON.УстановитьСтроку(Строка);
        Возврат ПрочитатьJSON(ЧтениеJSON);
    Исключение
        ДобавитьЛог("Ошибка разбора JSON: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;
КонецФункции

&НаСервере
Процедура ДобавитьЛог(Текст)
    ТекущийЛог = Элементы.Лог.ТекстРедактирования;
    ТекущийЛог = "" + Формат(ТекущаяДатаСеанса(), "ДФ='HH:mm:ss'") + " | " + Текст + Символы.ПС + ТекущийЛог;
    Элементы.Лог.ТекстРедактирования = ТекущийЛог;
КонецПроцедуры

#КонецОбласти
